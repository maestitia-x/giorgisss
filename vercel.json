{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/prizes/:id", "destination": "/api/prizes/[id]" },
    { "source": "/api/participants/:id", "destination": "/api/participants/[id]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
